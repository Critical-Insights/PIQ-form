# ─── Google Sheets ───────────────────────────────────────────────────
# Spreadsheet ID (the long string in the Sheet's URL between /d/ and /edit)
GOOGLE_SHEETS_ID=

# Service account email (looks like: name@project.iam.gserviceaccount.com)
GOOGLE_SERVICE_ACCOUNT_EMAIL=

# Service account private key. Paste the full key (BEGIN/END lines included)
# with literal \n in place of real newlines, wrapped in double quotes.
# Example: "-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"
GOOGLE_PRIVATE_KEY=

# ─── Resend (transactional email) ────────────────────────────────────
RESEND_API_KEY=

# Sender (must be on a Resend-verified domain).
# Plain address ("noreply@example.com") or display form ("Organization Name <noreply@example.com>").
FROM_EMAIL=

# Where Reply-To points (where attendee replies should go)
REPLY_TO_EMAIL=

# ─── Branding / copy ─────────────────────────────────────────────────
# Used in email subject, body, and the .ics calendar invite title
EVENT_NAME=Event Registration

# Shown in the email footer "Questions? <email>" line
SUPPORT_EMAIL=
